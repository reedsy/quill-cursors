{
  "name": "quill-cursors",
  "version": "5.0.0",
  "description": "A multi cursor module for Quill.",
  "keywords": [
    "quill",
    "module",
    "collaborative",
    "editing"
  ],
  "contributors": [
    "Pedro Machado Santa <pedro.santa@gmail.com>",
    "Alec Gibson <alec@reedsy.com>",
    "Oleg Petrov <oleg@reedsy.com>"
  ],
  "license": "MIT",
  "main": "dist/quill-cursors.umd.js",
  "module": "dist/quill-cursors.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/quill-cursors.es.js",
      "require": "./dist/quill-cursors.umd.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "dev": "vite"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reedsy/quill-cursors.git"
  },
  "peerDependencies": {
    "quill": ">=1.3.7"
  },
  "devDependencies": {
    "@reedsy/eslint-plugin": "^0.14.2",
    "@testing-library/jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.8.0",
    "jsdom": "^26.0.0",
    "quill": "^2.0.0",
    "quill-delta": "^5.1.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
