{
  "name": "quill-cursors",
  "version": "4.2.0",
  "description": "A multi cursor module for Quill.",
  "keywords": [
    "quill",
    "module",
    "collaborative",
    "editing"
  ],
  "contributors": [
    "Pedro Machado Santa <pedro.santa@gmail.com>",
    "Alec Gibson <alec@reedsy.com>",
    "Oleg Petrov <oleg@reedsy.com>"
  ],
  "license": "MIT",
  "main": "dist/quill-cursors.js",
  "types": "dist/index.d.ts",
  "style": "dist/quill-cursors.min.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/quill-cursors.js"
    },
    "./core": {
      "types": "./dist/index.core.d.ts",
      "default": "./dist/quill-cursors.core.js"
    },
    "./css": "./dist/quill-cursors.min.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "npm run lint && NODE_ENV=production webpack && sass assets/quill-cursors.scss dist/quill-cursors.min.css --style=compressed --no-source-map",
    "lint": "eslint '**/*'",
    "start": "webpack serve --open",
    "test": "NODE_ENV=test jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reedsy/quill-cursors.git"
  },
  "devDependencies": {
    "@reedsy/eslint-plugin": "^0.14.2",
    "@testing-library/jest-dom": "^5.16.1",
    "@types/jest": "^27.4.0",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "css-loader": "^6.6.0",
    "eslint": "^8.8.0",
    "jest": "^27.4.7",
    "quill": "^1.3.7",
    "quill-delta": "^4.2.2",
    "rangefix": "^0.2.10",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "^1.49.7",
    "sass-loader": "^12.4.0",
    "style-loader": "^3.3.1",
    "ts-jest": "^27.1.3",
    "ts-loader": "^9.2.6",
    "typescript": "^4.5.5",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.7.4"
  }
}
